#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Create virtualenv and install dependencies if needed
if [[ ! -d ".venv" ]]; then
    if command -v uv &>/dev/null; then
        uv venv
        uv pip install -r requirements.txt
    else
        python3 -m venv .venv
        .venv/bin/pip install -r requirements.txt
    fi
fi

.venv/bin/pytest "$@"
